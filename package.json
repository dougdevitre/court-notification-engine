{
  "name": "@justice-os/notifications",
  "version": "0.1.0",
  "description": "Smart court notification engine — multi-channel deadline reminders with escalation and recovery",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "justice",
    "legal",
