    "deadlines",
    "court",
    "reminders",
    "sms",
    "access-to-justice"
  ],
  "author": "Justice OS Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougdevitre/court-notification-engine.git"
  },
  "dependencies": {
    "cron": "^3.1.0",
    "handlebars": "^4.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cron": "^2.4.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
