# Court Notification Engine Configuration
# Copy this file to .env and fill in your values

# Application environment (development | staging | production)
NODE_ENV=development

# Server port
PORT=3000

# PostgreSQL connection string for notification data
DATABASE_URL=postgresql://localhost:5432/court_notifications

# Redis connection string for scheduling queue and caching
REDIS_URL=redis://localhost:6379

# Twilio SMS configuration
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid email configuration
SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=notifications@justice-os.org

# Firebase Cloud Messaging for push notifications
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY=your-firebase-key
